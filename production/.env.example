# Wazuh
INDEXER_PASSWORD=change_me_strong_password
API_USERNAME=wazuh-wui
API_PASSWORD=change_me_strong_password

# PostgreSQL (IRIS) — no @ symbol in passwords
POSTGRES_USER=iris
POSTGRES_PASSWORD=change_me_no_special_chars
POSTGRES_ADMIN_USER=iris
POSTGRES_ADMIN_PASSWORD=change_me_no_special_chars

# RabbitMQ (IRIS) — no @ symbol in passwords
RABBITMQ_USER=iris
RABBITMQ_PASSWORD=change_me_no_special_chars

# IRIS App
IRIS_SECRET_KEY=generate_with: openssl rand -hex 32
IRIS_SECURITY_PASSWORD_SALT=generate_with: openssl rand -hex 16
IRIS_ADM_EMAIL=admin@yourcompany.com
IRIS_ADM_PASSWORD=change_me_strong_password
IRIS_ADM_USERNAME=administrator

# Celery (must match RABBITMQ_USER and RABBITMQ_PASSWORD above)
CELERY_BROKER=amqp://iris:change_me_no_special_chars@iris-rabbitmq

# Wazuh -> IRIS integration (get from IRIS UI after first boot: avatar -> My Profile -> API Key)
IRIS_API_KEY=get_from_iris_ui_after_first_boot
